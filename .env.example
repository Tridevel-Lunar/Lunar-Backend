# Copy to backend/.env (never commit)
# cp .env.example .env

# --- URLs ---
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL ---
# Docker compose: override เป็น postgres:5432 อัตโนมัติ
# รัน backend นอก Docker + postgres ใน Docker:
DATABASE_URL=postgresql+psycopg://lunar:lunar@localhost:5432/lunar

# --- JWT ---
SECRET_KEY=dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- LAIKA (when implemented) ---
# GEMINI_API_KEY=
